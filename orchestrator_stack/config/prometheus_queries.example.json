{
  "cpu_util": "avg by (instance) (rate(node_cpu_seconds_total{mode!=\"idle\"}[5m]))",
  "mem_util": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
  "disk_util": "1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"})",
  "net_util": "sum by (instance) (rate(node_network_receive_bytes_total[5m]) + rate(node_network_transmit_bytes_total[5m]))"
}
